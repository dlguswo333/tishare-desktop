{
  "name": "tishare-desktop",
  "type": "module",
  "author": {
    "name": "dlguswo333"
  },
  "version": "0.5.2",
  "description": "Share files and folders across devices easily with cross-platform support.",
  "private": false,
  "devDependencies": {
    "@dlguswo333/react-simple-spinner": "^0.6.0",
    "@testing-library/react": "^16.3.0",
    "@types/eslint": "^8.44.7",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.6",
    "@typescript-eslint/parser": "^8.17.0",
    "@vitejs/plugin-react": "^4.7.0",
    "classnames": "^2.5.1",
    "concurrently": "^9.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^25.1.8",
    "eslint": "^9.16.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.13.0",
    "jsdom": "^26.1.0",
    "mocha": "^9.2.2",
    "nodemon": "^3.1.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sass": "^1.98.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vite-plugin-commonjs": "^0.10.4",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.1.0"
  },
  "homepage": "./",
  "main": "src/back/main.js",
  "scripts": {
    "start": "concurrently --kill-others \"npm run start:front\" \"npm run start:back\"",
    "start:front": "vite --config src/front/vite.config.js",
    "start:back": "nodemon --exec electron --trace-warnings .",
    "build": "npm run build:front && npm run build:back",
    "build:front": "vite build --config src/front/vite.config.js",
    "build:back": "electron-builder --publish never",
    "test": "npm run test:front -- --run && npm run test:back",
    "test:front": "vitest --root src/front",
    "test:back": "mocha ./src/back/back.test.js",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p src/front/tsconfig.json && tsc --noEmit -p src/back/tsconfig.json",
    "lint": "eslint"
  },
  "build": {
    "productName": "tiShare",
    "files": [
      "build/**/*",
      "public/**/*",
      "src/back/**/*",
      "src/defs.js"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png"
    },
    "directories": {
      "buildResources": "public"
    },
    "nsis": {
      "oneClick": false
    },
    "extends": null
  }
}
